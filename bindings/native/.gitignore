# Build artifacts from the native extension modules (source is tracked).
#
# Each package's vendor/{vibe.h,vibe_impl.c} IS tracked on purpose: a published
# package (PyPI / npm / RubyGems / crates.io) must ship the single-header lib so
# it compiles from source with no prebuilt libvibe.a. Regenerate with vendor.sh.

# C++ (_vibe literal)
cpp/test

# Python C-API
python/build/
python/dist/
python/*.so
python/*.egg-info/
python/__pycache__/

# Node N-API
node/build/
node/node_modules/

# Ruby C-extension
ruby/Makefile
ruby/*.o
ruby/*.so
ruby/*.gem
ruby/mkmf.log
ruby/.RUBYARCHDIR.time

# JNI
java/*.class
java/Vibe.h
java/libvibejni.so

# Zig
zig/.zig-cache/
zig/zig-out/

# Rust -sys
rust/target/
